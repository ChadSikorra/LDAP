version: 1

# Modify alice: replace sn
dn: cn=alice,dc=foo,dc=bar
changetype: modify
replace: sn
sn: Renamed
-

# Delete bob
dn: cn=bob,dc=foo,dc=bar
changetype: delete

# Add a new entry that will then be renamed below
dn: cn=carol,dc=foo,dc=bar
